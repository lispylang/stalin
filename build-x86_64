#!/bin/sh

# Stalin x86_64 Build Script via Rosetta
# Compiles Stalin for x86_64 on ARM64 Mac using Rosetta

echo "Building Stalin for x86_64 architecture via Rosetta..."

# Use x86_64 compiler
X86_CC="gcc"
X86_AR="ar"
X86_RANLIB="ranlib"

# Cosmopolitan toolchain for generated programs
COSMO_CC="$(pwd)/cosmocc/bin/cosmocc"

if [ ! -f "$COSMO_CC" ]; then
    echo "Error: Cosmopolitan toolchain not found at $COSMO_CC"
    echo "Please run ./install-cosmo-toolchain.sh first"
    exit 1
fi

# Run everything under Rosetta x86_64 emulation
arch -x86_64 /bin/sh << 'INNER_SCRIPT'

# Build GC library
echo "Building GC library (using stub)..."
gcc -c -O2 -fomit-frame-pointer gc_stub.c
ar rc include/libgc.a gc_stub.o
ranlib include/libgc.a
rm -f gc_stub.o

# Create minimal gc.h header
cat > include/gc.h << 'EOFGC'
#ifndef GC_H
#define GC_H
#include <stdlib.h>
void *GC_malloc(size_t size);
void *GC_malloc_atomic(size_t size);
void *GC_realloc(void *ptr, size_t size);
void GC_free(void *ptr);
void GC_init(void);
void GC_gcollect(void);
size_t GC_get_heap_size(void);
size_t GC_get_free_bytes(void);
void GC_set_warn_proc(void (*proc)(char *, int));
void *GC_malloc_uncollectable(size_t size);
void *GC_malloc_atomic_uncollectable(size_t size);
void GC_register_finalizer(void *obj, void (*fn)(void *, void *), void *cd, void (**ofn)(void *, void *), void **ocd);
int GC_invoke_finalizers(void);
void GC_enable_incremental(void);
void GC_disable(void);
void GC_enable(void);
#endif
EOFGC

# Create minimal gc_config_macros.h
cat > include/gc_config_macros.h << 'EOFGC2'
#ifndef GC_CONFIG_MACROS_H
#define GC_CONFIG_MACROS_H
/* Minimal GC config macros for stub */
#endif
EOFGC2

# Build libstalin.a
echo "Building libstalin.a..."
cd include
rm -f libstalin.a
gcc -c -O2 -fomit-frame-pointer xlib-stub.c
ar rc libstalin.a xlib-stub.o
ranlib libstalin.a
rm -f xlib-stub.o
cd ..

# Use IA32 bootstrap (works on x86_64)
echo "Using IA32 bootstrap..."
cp -f stalin-IA32.c stalin.c

# Build Stalin
echo "Compiling Stalin..."
gcc -o stalin -I./include -O3 -fomit-frame-pointer \
    -fno-strict-aliasing -Wno-pointer-to-int-cast -Wno-int-to-pointer-cast \
    stalin.c -L./include -lm -lgc -lstalin

echo "Stalin built successfully for x86_64!"

INNER_SCRIPT

# Create wrapper that uses Cosmopolitan for output
lib=$(pwd)/include
cat > stalin-cosmo << EOFWRAP
#!/bin/sh
arch -x86_64 $PWD/stalin -I $lib -copt -fno-strict-aliasing -cc "$COSMO_CC" "\$@"
EOFWRAP
chmod +x stalin-cosmo

echo ""
echo "✓ Stalin compiler ready!"
echo "  - Native binary: ./stalin (x86_64, runs via Rosetta)"
echo "  - Universal binary wrapper: ./stalin-cosmo"
