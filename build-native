#!/bin/sh

# Stalin Native Build Script
# Compiles Stalin with native compiler, configured to generate Cosmopolitan universal binaries

# Use native compiler for Stalin itself
NATIVE_CC="/usr/bin/gcc"
NATIVE_AR="/usr/bin/ar"
NATIVE_RANLIB="/usr/bin/ranlib"

# Cosmopolitan toolchain for generated programs
COSMO_CC="$(pwd)/cosmocc/bin/cosmocc"
COSMO_AR="$(pwd)/cosmocc/bin/cosmoar"

if [ ! -f "$COSMO_CC" ]; then
    echo "Error: Cosmopolitan toolchain not found at $COSMO_CC"
    echo "Please run ./install-cosmo-toolchain.sh first"
    exit 1
fi

# Build GC library with native compiler
echo "Building GC library with native compiler (using stub)..."
"$NATIVE_CC" -c -O2 -fomit-frame-pointer gc_stub.c
"$NATIVE_AR" rc include/libgc.a gc_stub.o
$NATIVE_RANLIB include/libgc.a
rm -f gc_stub.o

# Create minimal gc.h header
cat > include/gc.h << 'EOFGC'
#ifndef GC_H
#define GC_H
#include <stdlib.h>
void *GC_malloc(size_t size);
void *GC_malloc_atomic(size_t size);
void *GC_realloc(void *ptr, size_t size);
void GC_free(void *ptr);
void GC_init(void);
void GC_gcollect(void);
size_t GC_get_heap_size(void);
size_t GC_get_free_bytes(void);
void GC_set_warn_proc(void (*proc)(char *, int));
void *GC_malloc_uncollectable(size_t size);
void *GC_malloc_atomic_uncollectable(size_t size);
void GC_register_finalizer(void *obj, void (*fn)(void *, void *), void *cd, void (**ofn)(void *, void *), void **ocd);
int GC_invoke_finalizers(void);
void GC_enable_incremental(void);
void GC_disable(void);
void GC_enable(void);
#endif
EOFGC

# Create minimal gc_config_macros.h
cat > include/gc_config_macros.h << 'EOFGC2'
#ifndef GC_CONFIG_MACROS_H
#define GC_CONFIG_MACROS_H
/* Minimal GC config macros for stub */
#endif
EOFGC2

# Build libstalin.a with native compiler
echo "Building libstalin.a with native compiler..."
cd include
rm -f libstalin.a
"$NATIVE_CC" -c -O2 -fomit-frame-pointer xlib-stub.c
"$NATIVE_AR" rc libstalin.a xlib-stub.o
$NATIVE_RANLIB libstalin.a
rm -f xlib-stub.o
cd ..

# Use IA32 bootstrap
echo "Using IA32 bootstrap..."
cp -f stalin-IA32.c stalin.c

# Build Stalin with native compiler
echo "Compiling Stalin with native compiler..."
"$NATIVE_CC" -o stalin -I./include -O3 -fomit-frame-pointer \
    -fno-strict-aliasing -Wno-pointer-to-int-cast -Wno-int-to-pointer-cast \
    stalin.c -L./include -lm -lgc -lstalin

# Create wrapper that configures Stalin to use Cosmopolitan for output
lib=`pwd`/include
cat > stalin-cosmo << EOFWRAP
#!/bin/sh
$PWD/stalin -I $lib -copt -fno-strict-aliasing -cc "$COSMO_CC" "\$@"
EOFWRAP
chmod +x stalin-cosmo

echo "Stalin built successfully!"
echo "Use ./stalin for native compilation"
echo "Use ./stalin-cosmo to generate Cosmopolitan universal binaries"
